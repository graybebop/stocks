{"file":"index-Emdp7UE9.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;AAkDA,UAAM,SAAY,iBAAA;AAClB,UAAM,YAAY,aAAA;AAElB,UAAM,EAAE,MAAM,aAAY,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM;AAAA,MAC9B,GAAG,OAAO,OAAO,OAAO;AAAA,MACxB,EAAE,SAAS,EAAE,eAAe,UAAU,UAAU,KAAK,KAAG;AAAA,MAAE;AAAA;AAAA,IAAA,CAC5D;AAEA,UAAM,QAAQ,SAAS,MAAM,KAAK,OAAO,QAAQ,EAAE;AAEnD,aAAS,WAAW,SAAiB;AACnC,aAAO,IAAI,KAAK,OAAO,EAAE,mBAAmB,OAAO;AAAA,IACrD;;AA7DO,YAAA,OAAAC,eAAAC,WAAA,EAAA,OAAM,eAAW,MAAA,CAAA,CAAA,wQAAA;UAUPC,MAAA,OAAA,GAAO;;;;AAaGC,sBAAAD,MAAA,KAAA,IAAR,SAAI;uGAI6BE,eAAA,KAAK,EAAE,yDACIA,eAAA,KAAK,IAAI,6CACrBA,eAAA,KAAK,KAAK,4DACV,WAAW,KAAK,UAAU,CAAA;;;AAExD,YAAA,CAAAF,MAAA,KAAA,EAAM,QAAM;;;;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_unref","_ssrRenderList","_ssrInterpolate"],"sources":["../../../../pages/users/index.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-6\">\n    <div class=\"flex items-center justify-between\">\n      <div>\n        <h2 class=\"text-2xl font-bold text-gray-800\">사용자 관리</h2>\n        <p class=\"text-gray-500 text-sm mt-1\">전체 사용자 목록을 관리하세요.</p>\n      </div>\n    </div>\n\n    <!-- 테이블 -->\n    <div class=\"bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden\">\n      <div v-if=\"pending\" class=\"p-8 text-center text-gray-400\">불러오는 중...</div>\n\n      <table v-else class=\"w-full text-sm\">\n        <thead class=\"bg-gray-50 border-b border-gray-100\">\n          <tr>\n            <th class=\"text-left px-6 py-4 text-gray-500 font-medium\">ID</th>\n            <th class=\"text-left px-6 py-4 text-gray-500 font-medium\">이름</th>\n            <th class=\"text-left px-6 py-4 text-gray-500 font-medium\">이메일</th>\n            <th class=\"text-left px-6 py-4 text-gray-500 font-medium\">가입일</th>\n          </tr>\n        </thead>\n        <tbody class=\"divide-y divide-gray-50\">\n          <tr\n            v-for=\"user in users\"\n            :key=\"user.id\"\n            class=\"hover:bg-gray-50 transition-colors\"\n          >\n            <td class=\"px-6 py-4 text-gray-400\">#{{ user.id }}</td>\n            <td class=\"px-6 py-4 font-medium text-gray-800\">{{ user.name }}</td>\n            <td class=\"px-6 py-4 text-gray-600\">{{ user.email }}</td>\n            <td class=\"px-6 py-4 text-gray-400\">{{ formatDate(user.created_at) }}</td>\n          </tr>\n          <tr v-if=\"!users.length\">\n            <td colspan=\"4\" class=\"px-6 py-8 text-center text-gray-400\">사용자가 없습니다.</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ninterface User {\n  id: number\n  name: string\n  email: string\n  created_at: string\n}\n\nconst config    = useRuntimeConfig()\nconst authStore = useAuthStore()\n\nconst { data, pending } = await useFetch<{ data: User[] }>(\n  `${config.public.apiBase}/users`,\n  { headers: { Authorization: `Bearer ${authStore.token}` } }\n)\n\nconst users = computed(() => data.value?.data ?? [])\n\nfunction formatDate(dateStr: string) {\n  return new Date(dateStr).toLocaleDateString('ko-KR')\n}\n</script>\n"],"version":3}